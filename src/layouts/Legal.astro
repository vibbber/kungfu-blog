---
import Base from './Base.astro';
const { frontmatter } = Astro.props;
---
<Base title={`${frontmatter.title} — Kung Fu Family`} description={frontmatter.title}>
  <main class="legal">
    <a href="/" class="back">← Back to home</a>
    <article class="prose">
      <slot />
    </article>
  </main>

  <style is:global>
    .legal {
      max-width: 760px;
      margin: 0 auto;
      padding: 48px 24px 96px;
    }
    .legal .back {
      display: inline-block;
      margin-bottom: 32px;
      font-size: 14px;
      color: var(--text-secondary);
    }
    .legal .back:hover { color: var(--accent); }
    .prose {
      font-size: 16px;
      line-height: 1.7;
      color: var(--text);
    }
    .prose h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 2.4rem;
      line-height: 1.2;
      margin-bottom: 24px;
    }
    .prose h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.6rem;
      margin-top: 40px;
      margin-bottom: 16px;
    }
    .prose h3 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-top: 28px;
      margin-bottom: 12px;
    }
    .prose p { margin-bottom: 16px; }
    .prose ul, .prose ol { margin: 0 0 16px 24px; }
    .prose li { margin-bottom: 6px; }
    .prose a {
      color: var(--accent);
      text-decoration: underline;
    }
    .prose hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 40px 0;
    }
    .prose strong { font-weight: 600; }
    .prose code {
      font-family: ui-monospace, monospace;
      font-size: 0.9em;
      background: var(--bg-hover);
      padding: 2px 6px;
      border-radius: 4px;
    }
  </style>
</Base>
