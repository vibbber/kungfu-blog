---
import Base from '../layouts/Base.astro';
import { articles, topics } from '../data/articles';
---

<Base
  title="Kung Fu Family — Parenting Strategies from Books"
  description="Evidence-based parenting strategies extracted from research and books. Practical techniques for raising children with purpose."
>

  <!-- Top bar -->
  <header class="topbar">
    <a href="/browse" class="logo" aria-label="Kung Fu Family">
      <img src="/images/logo.png" alt="Kung Fu Family" />
    </a>
    <nav class="topnav">
      <a href="/">Home</a>
      <a href="/browse" class="active">Blog</a>
      <a href="https://app.kungfu.family" class="cta">Try it free</a>
    </nav>
  </header>

  <div class="layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <nav class="sidebar-nav">
        <div class="sidebar-section">
          <div class="sidebar-label">TOPIC</div>
          <button class="sidebar-item active" data-filter="topic" data-value="">All</button>
          {topics.map(t => (
            <button class="sidebar-item" data-filter="topic" data-value={t}>{t}</button>
          ))}
        </div>
      </nav>
    </aside>

    <!-- Masonry grid -->
    <main class="masonry-container">
      <div class="masonry" id="masonry">
        {articles.map(a => (
          <a
            href={`/${a.slug}`}
            class="card"
            data-topic={a.topic}
          >
            <div class="card-image" style={`aspect-ratio: ${a.imageAspect}`}>
              <img src={a.image} alt={a.imageAlt} loading="lazy" width={a.imageWidth} height={a.imageHeight} />
            </div>
            <div class="card-content">
              <span class="card-topic">{a.topic}</span>
              <h2 class="card-title">{a.title}</h2>
              <p class="card-subtitle">{a.subtitle}</p>
            </div>
          </a>
        ))}
      </div>
    </main>
  </div>

  <!-- Mobile filter bar -->
  <div class="mobile-filters">
    <div class="mobile-filter-scroll">
      <button class="mobile-chip active" data-filter="topic" data-value="">All</button>
      {topics.map(t => (
        <button class="mobile-chip" data-filter="topic" data-value={t}>{t}</button>
      ))}
    </div>
  </div>

  <style>
    .topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(250, 249, 246, 0.75);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border-bottom: none;
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      display: inline-flex;
      align-items: center;
    }
    .logo img {
      height: 48px;
      width: auto;
      display: block;
    }

    .article-count {
      font-size: 13px;
      color: var(--text-muted);
    }

    .topnav {
      display: flex;
      align-items: center;
      gap: 28px;
    }
    .topnav a {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-secondary);
      transition: color 0.2s ease;
    }
    .topnav a:hover,
    .topnav a.active {
      color: var(--accent);
    }
    .topnav a.cta {
      background: #00685c;
      color: #fff;
      padding: 0.65rem 1.5rem;
      border-radius: 9999px;
      font-weight: 600;
      white-space: nowrap;
      transition: transform 0.2s ease, filter 0.2s ease;
    }
    .topnav a.cta:hover {
      color: #fff;
      transform: scale(1.05);
      filter: brightness(1.05);
    }
    @media (max-width: 640px) {
      .topnav { gap: 16px; }
      .topnav a { font-size: 0.9rem; }
      .topnav a.cta { padding: 0.45rem 1rem; }
    }

    .layout {
      display: flex;
      min-height: calc(100vh - 53px);
    }

    .sidebar {
      width: 240px;
      flex-shrink: 0;
      border-right: none;
      padding: 32px 0;
      position: sticky;
      top: 72px;
      height: calc(100vh - 72px);
      overflow-y: auto;
    }

    .sidebar-section {
      margin-bottom: 32px;
    }

    .sidebar-label {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 0 32px;
      margin-bottom: 12px;
    }

    .sidebar-item {
      display: block;
      width: 100%;
      text-align: left;
      padding: 10px 32px;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 14px;
      color: var(--text-secondary);
      background: none;
      border: none;
      cursor: pointer;
      transition: all 0.15s;
      border-radius: 0;
    }

    .sidebar-item:hover {
      background: var(--bg-hover);
      color: var(--text);
    }

    .sidebar-item.active {
      color: var(--accent);
      font-weight: 600;
      background: var(--accent-light);
    }

    .masonry-container {
      flex: 1;
      padding: 40px 48px 80px;
      min-width: 0;
      display: flex;
      justify-content: center;
    }

    .masonry {
      width: 100%;
      max-width: 1200px;
      column-count: 3;
      column-gap: 32px;
    }

    .card {
      display: block;
      position: relative;
      -webkit-column-break-inside: avoid;
      page-break-inside: avoid;
      break-inside: avoid;
      margin-bottom: 32px;
      background: #ffffff;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 0 40px rgba(27, 28, 26, 0.06);
      border: none;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 48px rgba(27, 28, 26, 0.1);
    }

    .card-image {
      overflow: hidden;
    }

    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s;
    }

    .card:hover .card-image img {
      transform: scale(1.03);
    }

    .card-content {
      padding: 20px 24px 24px;
    }

    .card-topic {
      display: inline-block;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .card-title {
      font-family: 'Noto Serif', Georgia, serif;
      font-size: 1.3rem;
      line-height: 1.25;
      margin-bottom: 8px;
      color: var(--text);
      font-weight: 600;
    }

    .card-subtitle {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.93rem;
      color: var(--text-secondary);
      line-height: 1.55;
    }

    .card.hidden {
      display: none;
    }

    .mobile-filters {
      display: none;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(250, 250, 248, 0.97);
      backdrop-filter: blur(20px);
      border-top: 1px solid var(--border);
      padding: 10px 0;
      z-index: 100;
    }

    .mobile-filter-scroll {
      display: flex;
      gap: 8px;
      padding: 0 12px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .mobile-filter-scroll::-webkit-scrollbar { display: none; }

    .mobile-chip {
      flex-shrink: 0;
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 500;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text-secondary);
      cursor: pointer;
      font-family: inherit;
      transition: all 0.15s;
    }

    .mobile-chip.active {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    @media (max-width: 1100px) {
      .masonry {
        column-count: 2;
        column-gap: 28px;
      }
      .masonry-container { padding: 32px; }
    }

    @media (max-width: 768px) {
      .sidebar { display: none; }
      .mobile-filters { display: block; }
      .masonry-container { padding: 20px 20px 100px; }
      .masonry {
        column-count: 1;
        column-gap: 0;
      }
      .card {
        margin-bottom: 16px;
        border-radius: 16px;
      }
    }
  </style>

  <script>
    const cards = document.querySelectorAll('.card') as NodeListOf<HTMLElement>;
    let currentFilter = '';

    function applyFilter(value: string) {
      currentFilter = value;
      cards.forEach(card => {
        const match = !value || card.dataset.topic === value;
        card.classList.toggle('hidden', !match);
      });
    }

    document.querySelectorAll('.sidebar-item').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const value = el.dataset.value || '';

        document.querySelectorAll('.sidebar-item').forEach(b => b.classList.remove('active'));
        el.classList.add('active');

        applyFilter(value);
      });
    });

    document.querySelectorAll('.mobile-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const value = el.dataset.value || '';

        document.querySelectorAll('.mobile-chip').forEach(b => b.classList.remove('active'));
        el.classList.add('active');

        applyFilter(value);
      });
    });
  </script>

</Base>
