---
import Article from '../layouts/Article.astro';
import { articles, type Article as ArticleType } from '../data/articles';
import { readFile } from 'fs/promises';
import { join } from 'path';
import articleDesignSystem from '../styles/article-design-system.css?raw';

export async function getStaticPaths() {
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props as { article: ArticleType };

// Read HTML content
const contentPath = join(process.cwd(), 'content', `${article.slug}.html`);
let rawHtml: string;
try {
  rawHtml = await readFile(contentPath, 'utf-8');
} catch (err) {
  throw new Error(`Missing content file: content/${article.slug}.html`);
}

// Extract body content (between <body> and </body>)
const bodyMatch = rawHtml.match(/<body[^>]*>([\s\S]*)<\/body>/i);
const bodyContent = bodyMatch ? bodyMatch[1] : rawHtml;

// Extract embedded styles (between <style> and </style> in head)
const styleMatch = rawHtml.match(/<style[^>]*>([\s\S]*?)<\/style>/i);
const embeddedStyles = styleMatch ? styleMatch[1] : '';

// Replace .png/.jpg/.jpeg with .webp in image paths
let webpContent = bodyContent
  .replace(/\.(png|jpg|jpeg)"/g, '.webp"')
  .replace(/\.(png|jpg|jpeg)'/g, ".webp'");

// Scope blog CSS to prevent overriding site-level styles.
// 1. Strip universal * reset (Base.astro already has one)
// 2. Replace :root and body with scoped .article-content class
// 3. Scope bare element selectors (h2, h3, footer, etc.) to .article-content
// 4. Remap legacy palette hex codes to Sanctuary tokens. 768+ bespoke class
//    selectors use sage/coral accents that can't be reached via selector-based
//    overrides, so we surgically rewrite the colors at injection time.
const paletteRemap: Record<string, string> = {
  // Sage greens → primary
  '#5c8a5a': '#00685c',
  '#5C8A5A': '#00685c',
  '#4a7a4a': '#00685c',
  '#4A7A4A': '#00685c',
  '#edf7ed': '#efeeeb',
  '#EDF7ED': '#efeeeb',
  // Coral / alert reds → secondary-container / secondary
  '#e8a598': '#fe6d59',
  '#E8A598': '#fe6d59',
  '#fef3f0': '#f4f3f0',
  '#FEF3F0': '#f4f3f0',
  '#c0392b': '#ac3224',
  '#C0392B': '#ac3224',
  // Legacy dark blue text → on-surface charcoal
  '#1a1a2e': '#1b1c1a',
  '#1A1A2E': '#1b1c1a',
  // Legacy cream background → surface
  '#faf6f0': '#faf9f6',
  '#FAF6F0': '#faf9f6',
  // Legacy warm neutrals → sanctuary neutrals
  '#e0ddd6': '#e3e2df',
  '#E0DDD6': '#e3e2df',
  '#bdbdb5': '#bec9c5',
  '#BDBDB5': '#bec9c5',
  '#eeeae4': '#efeeeb',
  '#EEEAE4': '#efeeeb',
};

let scopedStyles = embeddedStyles
  .replace(/\*,?\s*\*::before,?\s*\*::after\s*\{[^}]*\}/g, '')
  .replace(/:root\s*\{/g, '.article-content {')
  .replace(/^\s*body\s*\{/gm, '.article-content {')
  .replace(/^(\s*)(h[1-6]|footer|header|nav|main|section|article|aside|p|ul|ol|li|table|blockquote|figure|figcaption|a)\s*\{/gm, '$1.article-content $2 {');

for (const [from, to] of Object.entries(paletteRemap)) {
  scopedStyles = scopedStyles.split(from).join(to);
  // Also remap legacy hexes in inline style="" attributes on body elements.
  webpContent = webpContent.split(from).join(to);
}

// Preserve deliberately dark/gradient card backgrounds from per-article CSS.
// The design-system override uses selectors like .article-content [class*="-box"]
// (specificity 0,2,0) which beats a plain class selector like .highlight-box
// (0,1,0) even when both have !important — specificity trumps source order.
// For rule blocks that contain a deliberately dark background (gradient or
// primary/secondary palette fill) or white text, we (a) add !important to the
// color/background declarations, and (b) bump selector specificity by tripling
// each class in the selector (.highlight-box → .highlight-box.highlight-box
// .highlight-box, specificity 0,3,0), guaranteeing they beat the design-system
// override for elements the author deliberately styled dark.
scopedStyles = scopedStyles.replace(/([^{}]+)\{([^}]*)\}/g, (match, selector, body) => {
  const hasDarkBg = /background(?:-color)?\s*:[^;}]*(?:linear-gradient|#00685c|#2d8175|#ac3224|#fe6d59)/i.test(body);
  const hasWhiteColor = /color\s*:\s*(?:white|#fff|#ffffff|rgba\(\s*255)/i.test(body);
  if (!hasDarkBg && !hasWhiteColor) return match;

  let newBody = body;
  if (hasDarkBg) {
    newBody = newBody.replace(
      /(background(?:-color)?\s*:\s*[^;}]*(?:linear-gradient|#00685c|#2d8175|#ac3224|#fe6d59)[^;}]*?)(\s*;|\s*(?=$))/gi,
      (_m, decl, end) => (decl.includes('!important') ? decl + end : decl + ' !important' + end)
    );
  }
  if (hasWhiteColor) {
    newBody = newBody.replace(
      /(color\s*:\s*(?:white|#fff|#ffffff|rgba\(\s*255[^)]*\))[^;}]*?)(\s*;|\s*(?=$))/gi,
      (_m, decl, end) => (decl.includes('!important') ? decl + end : decl + ' !important' + end)
    );
  }

  // Triple each per-article class in the selector to bump specificity past
  // the design-system override's attribute-selector rules (0,2,0). Skip the
  // `.article-content` scope prefix that our own pipeline added — tripling
  // it would also beat bare-element rules we intentionally keep at 0,1,1.
  const newSelector = selector.replace(/\.([a-zA-Z_][\w-]*)/g, (_m, cls) =>
    cls === 'article-content' ? '.' + cls : '.' + cls + '.' + cls + '.' + cls,
  );

  return newSelector + '{' + newBody + '}';
});

// DESIGN.md forbids corner radii under 16px. Bump any small radius value in
// the per-article CSS and inline styles up to 16px so nothing reads "clinical".
const bumpRadius = (css: string) =>
  css.replace(/border-radius:\s*([0-9]+(?:\.[0-9]+)?)px/gi, (match, n) => {
    const v = parseFloat(n);
    return v > 0 && v < 16 ? 'border-radius: 16px' : match;
  });
scopedStyles = bumpRadius(scopedStyles);
webpContent = bumpRadius(webpContent);
---

<Article article={article}>
  {scopedStyles && <Fragment set:html={`<style>${scopedStyles}</style>`} />}
  <Fragment set:html={`<style>${articleDesignSystem}</style>`} />
  <div class="article-content">
    <Fragment set:html={webpContent} />
  </div>
</Article>
